USER_TITLE=sir
WAKE_WORD=jarvis

# ── LLM ───────────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── TTS ───────────────────────────────────────────────────────────────────────
JARVIS_TTS_RATE=175
JARVIS_TTS_VOLUME=0.95

# ── Email (Gmail App Password — never your real password) ─────────────────────
JARVIS_EMAIL=your@gmail.com
JARVIS_EMAIL_PASSWORD=your_app_password_here
JARVIS_EMAIL_HOST=imap.gmail.com
JARVIS_EMAIL_PORT=993

# ── Calendar (path to exported .ics file) ────────────────────────────────────
JARVIS_CALENDAR_ICS=

# ── Spotify (optional — macOS AppleScript works without this) ─────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

